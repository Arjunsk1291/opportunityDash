# --- BACKEND CONFIGURATION ---
PORT=3001
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/opportunity-dashboard
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Security & Auth
JWT_SECRET=replace-with-long-random-secret
SESSION_JWT_SECRET=replace-with-long-random-secret
DEV_JWT_SECRET=dev-only-secret
BOOTSTRAP_ADMIN_SECRET=admin-bootstrap-secret
ALLOW_LEGACY_USERNAME_AUTH=true
ALLOW_PROD_USERNAME_ALIASES=false
MASTER_USERS=arjun.s@avenirengineering.com

# Microsoft Azure / Graph API Config
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
GRAPH_CLIENT_SECRET=your-client-secret
TELECAST_SENDER=sender.email@yourdomain.com
AZURE_REDIRECT_URI=https://opportunitydash.onrender.com/auth/callback
AZURE_REDIRECT_URI_DEV=http://localhost:5173

# Debugging Flags
MAIL_DEBUG=false
NOTIFICATION_DEBUG=false
GRAPH_TOKEN_DEBUG=false

# Offline Mode
DISABLE_MONGODB=false

# --- FRONTEND CONFIGURATION ---
VITE_API_URL=/api
VITE_SHAREPOINT_URL=
VITE_DEFAULT_MASTER_USERNAME=
VITE_DEFAULT_SERVICE_ACCOUNT=
