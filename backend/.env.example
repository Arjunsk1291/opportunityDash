PORT=3001
MONGODB_URI=mongodb://localhost:27017/opportunity-dashboard
REQUEST_BODY_LIMIT=10mb

# Session/JWT hardening (set a strong random secret in production)
SESSION_JWT_SECRET=replace-with-long-random-secret
SESSION_TOKEN_TTL=12h

# Set to false in production to disallow legacy email bearer tokens
ALLOW_LEGACY_EMAIL_BEARER=false

# Microsoft Graph confidential client credentials
GRAPH_TENANT_ID=your-tenant-id
GRAPH_CLIENT_ID=your-client-id
# IMPORTANT: use the secret VALUE (password-like string), not the Secret ID GUID
GRAPH_CLIENT_SECRET=your-client-secret-value

# Optional: only these delegated bootstrap usernames can be used for /api/graph/auth/bootstrap
# Comma-separated lowercase emails
GRAPH_BOOTSTRAP_ALLOWED_USERS=service.user@yourdomain.com

# Optional: custom encryption key for stored delegated refresh token
GRAPH_TOKEN_ENCRYPTION_KEY=replace-with-random-long-secret

# Optional: true to print masked token env diagnostics in backend logs
GRAPH_TOKEN_DEBUG=false
